// Windows resource file
// Embeds version info and application icon into the .exe

#include <windows.h>

// Application icon
IDI_ICON1 ICON "icons/app.ico"

// Version information
VS_VERSION_INFO VERSIONINFO
FILEVERSION     1,0,0,0
PRODUCTVERSION  1,0,0,0
FILEFLAGSMASK   VS_FFI_FILEFLAGSMASK
FILEFLAGS       0
FILEOS          VOS_NT_WINDOWS32
FILETYPE        VFT_APP
FILESUBTYPE     VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904E4"
        BEGIN
            VALUE "CompanyName",      "komica7.org"
            VALUE "FileDescription",  "Claude Usage Monitor"
            VALUE "FileVersion",      "1.0.0.0"
            VALUE "InternalName",     "ClaudeUsageMonitor"
            VALUE "LegalCopyright",   "MIT License"
            VALUE "OriginalFilename", "ClaudeUsageMonitor.exe"
            VALUE "ProductName",      "Claude Usage Monitor"
            VALUE "ProductVersion",   "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1252
    END
END
